# JuKa Project Configuration
# Copy this file to .env and adjust the paths for your system.
# The .env file is in .gitignore and will NOT be committed to git.

# Root directory containing raw GPR data (original .DT1/.HD/.gp2 files)
DATA_DIR=/your/data/folder

# =============================================================================
# Recipe Engine
# =============================================================================
RECIPE_FILE=recipe_steps.txt
RECIPE_NAME=default
RECIPE_VERSION=v1
RECIPE_DRY_RUN=FALSE
PRINT_RECIPE_PLAN=TRUE

# Per-file processing parallelism (flow inside each file remains sequential)
FILE_PARALLEL_ENABLED=FALSE
FILE_PARALLEL_WORKERS=2

# Test mode
TEST_MODE=TRUE
TEST_MAX_FILES=1

# Error handling for steps: abort | skip
STEP_ON_ERROR_DEFAULT=abort

# Keep header t0 where firstBreakToTime0 returns invalid values
USE_HEADER_T0_BASELINE=TRUE

# Save per-file recipe manifest
SAVE_MANIFEST=TRUE

# Processing parameters for Script 01 belong in recipe_steps.txt.
# Keep .env for global runtime settings and settings shared with other scripts.

# Radar wave velocity [m/ns] for other scripts that may still use a global value
V_RADAR=0.1

# PNG output dimensions
PNG_W=1400
PNG_H=800
PNG_RES=120

# Interpolation parameters
DX=0.1
DY=0.1
DZ=2.0
MBA_H=6

# Coordinate reference system
CRS_SURVEY=EPSG:28992
