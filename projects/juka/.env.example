# JuKa Project Configuration
# Copy this file to .env and adjust the paths for your system.
# The .env file is in .gitignore and will NOT be committed to git.

# Root directory containing raw GPR data (original .DT1/.HD/.gp2 files)
DATA_DIR=/your/data/folder

# Radar wave velocity [m/ns] for depth conversion and migration
V_RADAR=0.1

# Dewow: running-median window length [samples]
DEWOW_W=50

# Bandpass filter: fractions of nominal antenna frequency
# Example: 0.3 × 250 MHz = 75 MHz (low), 1.3 × 250 MHz = 325 MHz (high)
F_LOW_FRAC=0.3
F_HIGH_FRAC=1.3

# T-power gain parameters
TPOWER_ALPHA=1.0
TPOWER_TE=200
TPOWER_TCST=50

# Time-zero (first-break) detection parameters
T0_WINDOW=10
T0_THR=0.05

# Toggle optional processing steps
DECONV_ENABLED=TRUE
MIGRATE_ENABLED=TRUE

# Deconvolution parameters
DECONV_NCOEF=41
DECONV_P=0.1

# PNG output dimensions
PNG_W=1400
PNG_H=800
PNG_RES=120

# Interpolation parameters
DX=0.1
DY=0.1
DZ=2.0
MBA_H=6

# Coordinate reference system
CRS_SURVEY=EPSG:28992
